#!/usr/bin/env bash

source $TOOLS/dot-color

usage="NAME
      bb-clone - clone repos quickly from my work bitbucket team

SYNOPSIS
      ssh-create [-h] -n my-repo


ARGUMENTS
       -n name
          Name of bitbucket git repository.

          Example:
              bb-clone -n webcenterpoint
"

while test $# -gt 0; do
	  case "$1" in
        --help|-h|-\?)
            echo "$usage" >&2
            exit
            ;;
        -n|--repo-name)
            repo=$2
            shift
            ;;
        \?)
            echo $(color $Red "Error: Invalid flag: $1") >&2
            exit 1
            ;;
        *)
            echo $(color $Red "Error: Invalid flag: $1") >&2
            exit 1
            break
    esac
    shift
done


if [[ -z "${repo}" ]]; then
    color $Red "Error: You must provide a repo name via the -n flag.\n"
    echo "$usage"
    exit
fi
# Archive-candidate (Story 2.1): no longer used. Org name parameterized to keep it
# out of this public repo; full removal from git history is the privacy follow-up.
: "${BITBUCKET_ACCOUNT:?set BITBUCKET_ACCOUNT to your Bitbucket team/workspace}"
git clone "git@bitbucket.org:${BITBUCKET_ACCOUNT}/${repo}.git" "$HOME/code/${repo}"
