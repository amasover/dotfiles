#!/usr/bin/env bash
#
# aur-quarantine — time-delayed, risk-aware AUR upgrades.
#
# Defense in depth against freshly-weaponized AUR packages (cf. the June 2026 AUR
# malware incident). Rather than blindly upgrading to the latest AUR version, only
# take versions that have been public long enough to be vetted, and make anything
# riskier an explicit, manual decision.
#
# Signals (per pending update):
#   - age:        a version's PKGBUILD commit must be older than AUR_QUARANTINE_DAYS.
#   - orphaned:   a package with no current maintainer is held (adoption-attack vector).
#   - maintainer: if the maintainer changed vs your trusted baseline, the update is
#                 hard-stopped and flagged for explicit review — even if exempted.
#
# `plan` (what `update` runs) decides, per package:
#   - AUTO  -> printed on STDOUT; the caller upgrades to latest via the AUR helper.
#             Happens when the latest version is already aged, OR the package is
#             exempted (`auto`) and the maintainer is unchanged.
#   - MANUAL/HELD -> printed on STDERR as a human report with AUR links + the exact
#             copy-paste command (accept / update / auto). Stepping to an older
#             pinned version is NEVER automatic; it's suggested as `update <pkg>`.
#
# Subcommands:
#   (default)/plan    classify pending updates; AUTO list to stdout, report to stderr.
#   update PKG...      manually build+install the newest vetted (aged) version of PKG.
#   accept PKG...      trust the current maintainer of PKG (clears a change flag).
#   auto PKG...        take PKG's updates immediately, skipping the age delay
#                      (maintainer changes are still flagged). auto-off to undo.
#   auto-off PKG...    stop auto-updating PKG.
#   seed               record current maintainers of installed AUR pkgs as trusted
#                      (adds missing only; announces first-seen packages).
#   build BASE SHA     (internal) build+install pkgbase BASE at AUR git commit SHA.
#
# Config (env):
#   AUR_QUARANTINE_DAYS           per-version age threshold, days (default 14). <=0 disables.
#   AUR_MAINTAINER_CHANGE_DAYS    longer window for a changed maintainer (default 28).
#   AUR_ALLOW_ORPHAN             =1 allow orphaned-package updates (default: hold).
#   AUR_HELPER                    helper for `-Qua` and AUR installs (default: yay).
#
# State:  ${XDG_STATE_HOME:-~/.local/state}/aur-quarantine/{maintainers.tsv,exempt.txt}
# Cache:  ${XDG_CACHE_HOME:-~/.cache}/aur-quarantine/<pkgbase>   (AUR git clones)
#
# Only `update`/`build` install anything; everything else queries, clones to cache, prints.

set -uo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/aur-quarantine"
baseline="$state_dir/maintainers.tsv"
exempt_file="$state_dir/exempt.txt"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/aur-quarantine"
PACMAN=/usr/bin/pacman          # bypass the `pacman='sudo pacman'` shell alias; -Q needs no root
AURWEB="https://aur.archlinux.org/packages"

# rpc_info NAME...  ->  "name<TAB>pkgbase<TAB>lastmod<TAB>maintainer<TAB>outofdate"
rpc_info() {
    (( $# == 0 )) && return 0
    local p args=()
    for p in "$@"; do args+=(--data-urlencode "arg[]=$p"); done
    curl -fsG --max-time 20 "${args[@]}" 'https://aur.archlinux.org/rpc/v5/info' 2>/dev/null \
        | jq -r '.results[] | [.Name, .PackageBase, (.LastModified|tostring), (.Maintainer // ""), (.OutOfDate|tostring)] | @tsv'
}

load_baseline() { declare -gA trusted=(); [[ -f $baseline ]] || return 0
    local k v; while IFS=$'\t' read -r k v; do [[ -n $k ]] && trusted[$k]=$v; done < "$baseline"; }
save_baseline() { mkdir -p "$state_dir"; : > "$baseline.tmp"
    local k; for k in "${!trusted[@]}"; do printf '%s\t%s\n' "$k" "${trusted[$k]}" >> "$baseline.tmp"; done
    mv "$baseline.tmp" "$baseline"; }
load_exempt() { declare -gA exempt=(); [[ -f $exempt_file ]] || return 0
    local l; while read -r l; do [[ -n $l ]] && exempt[$l]=1; done < "$exempt_file"; }
save_exempt() { mkdir -p "$state_dir"; : > "$exempt_file.tmp"
    local k; for k in "${!exempt[@]}"; do echo "$k" >> "$exempt_file.tmp"; done
    mv "$exempt_file.tmp" "$exempt_file"; }

fetch_repo() {                  # $1=pkgbase -> ensures clone in cache; echoes its path
    local base=$1 dir="$cache_dir/$1"
    mkdir -p "$cache_dir"
    if [[ -d $dir/.git ]]; then
        git -C "$dir" fetch --quiet origin 2>/dev/null || return 1
        git -C "$dir" reset --quiet --hard origin/HEAD 2>/dev/null || true
    else
        git clone --quiet "https://aur.archlinux.org/${base}.git" "$dir" 2>/dev/null || return 1
    fi
    printf '%s\n' "$dir"
}

srcinfo_version() {             # stdin = .SRCINFO -> "epoch:pkgver-pkgrel"
    awk -F' = ' '
        /^[[:space:]]*pkgver = /{pv=$2} /^[[:space:]]*pkgrel = /{pr=$2} /^[[:space:]]*epoch = /{ep=$2}
        END{ if(ep!="") printf "%s:",ep; printf "%s-%s",pv,pr }'
}

# newest .SRCINFO commit with date <= cutoff AND version > installed; echoes "sha<TAB>ver"
target_at_or_before() {         # $1=repo_dir $2=cutoff_epoch $3=installed_ver
    local dir=$1 cutoff=$2 inst=$3 h ct ver
    while read -r h ct; do
        (( ct > cutoff )) && continue
        ver=$(git -C "$dir" show "$h:.SRCINFO" 2>/dev/null | srcinfo_version)
        [[ -z $ver || $ver == "-" ]] && return 1
        if [[ -z $inst ]] || (( $(vercmp "$ver" "$inst") > 0 )); then printf '%s\t%s\n' "$h" "$ver"; return 0; fi
        return 1
    done < <(git -C "$dir" log --format='%H %ct' -- .SRCINFO)
    return 1
}

cmd_seed() {
    load_baseline
    local -a installed; mapfile -t installed < <("$PACMAN" -Qqm 2>/dev/null)
    (( ${#installed[@]} == 0 )) && { echo "aur-quarantine: no foreign/AUR packages installed." >&2; return 0; }
    local name base lm mt od added=0
    while IFS=$'\t' read -r name base lm mt od; do
        [[ -z $name ]] && continue
        if [[ -z ${trusted[$name]+x} ]]; then trusted[$name]=$mt; ((added++))
            echo "aur-quarantine: now trusting $name @ ${mt:-ORPHANED} (first seen)." >&2; fi
    done < <(rpc_info "${installed[@]}")
    save_baseline
    (( added > 0 )) && echo "aur-quarantine: recorded $added new package(s); baseline now ${#trusted[@]}." >&2
    return 0
}

cmd_accept() {
    (( $# )) || { echo "usage: aur-quarantine accept PKG..." >&2; return 2; }
    load_baseline; local name base lm mt od
    while IFS=$'\t' read -r name base lm mt od; do
        [[ -z $name ]] && continue
        trusted[$name]=$mt; echo "aur-quarantine: accepted maintainer for $name (${mt:-ORPHANED})." >&2
    done < <(rpc_info "$@")
    save_baseline
}

cmd_auto() {
    (( $# )) || { echo "usage: aur-quarantine auto PKG..." >&2; return 2; }
    load_exempt; local p
    for p in "$@"; do exempt[$p]=1
        echo "aur-quarantine: '$p' set to auto-update (age delay skipped; maintainer changes still flagged)." >&2; done
    save_exempt
}
cmd_auto_off() {
    (( $# )) || { echo "usage: aur-quarantine auto-off PKG..." >&2; return 2; }
    load_exempt; local p
    for p in "$@"; do unset 'exempt[$p]'; echo "aur-quarantine: '$p' no longer auto-updates." >&2; done
    save_exempt
}

cmd_plan() {
    local helper="${AUR_HELPER:-yay}"
    local threshold_days="${AUR_QUARANTINE_DAYS:-14}"
    local allow_orphan="${AUR_ALLOW_ORPHAN:-0}"

    local -a pending; mapfile -t pending < <("$helper" -Qua 2>/dev/null | awk 'NF{print $1}')
    (( ${#pending[@]} == 0 )) && return 0
    load_baseline; load_exempt
    [[ -f $baseline ]] || echo "aur-quarantine: no maintainer baseline yet — run 'aur-quarantine seed'." >&2

    local now; now=$(date +%s)
    declare -A pbase=() lastmod=() maint=() ood=()
    local name base lm mt od
    while IFS=$'\t' read -r name base lm mt od; do
        [[ -z $name ]] && continue
        pbase[$name]=$base; lastmod[$name]=$lm; maint[$name]=$mt; ood[$name]=$od
    done < <(rpc_info "${pending[@]}")

    local -a r_maint=() r_step=() r_orphan=() r_hold=()
    local p inst cutoff repo res ver
    for p in "${pending[@]}"; do
        base=${pbase[$p]:-}
        if [[ -z $base ]]; then r_hold+=("$p -- not in AUR RPC; cannot verify"); continue; fi
        mt=${maint[$p]}
        if [[ -z $mt && $allow_orphan != 1 ]]; then r_orphan+=("$p|$AURWEB/$p"); continue; fi
        if [[ -n ${trusted[$p]+x} && ${trusted[$p]} != "$mt" ]]; then
            r_maint+=("$p|${trusted[$p]:-ORPHANED}|${mt:-ORPHANED}|$AURWEB/$p"); continue
        fi
        lm=${lastmod[$p]}
        if is_exempt_p "$p" || (( threshold_days <= 0 )) || (( now - lm >= threshold_days*86400 )); then
            echo "$p"; continue                       # AUTO: upgrade to latest
        fi
        repo=$(fetch_repo "$base") || { r_hold+=("$p -- could not fetch AUR git ($base)"); continue; }
        inst=$("$PACMAN" -Q "$p" 2>/dev/null | awk '{print $2}')
        cutoff=$(( now - threshold_days*86400 ))
        if res=$(target_at_or_before "$repo" "$cutoff" "$inst"); then
            ver=${res#*$'\t'}; r_step+=("$p|$ver|$AURWEB/$p")
        else
            r_hold+=("$p -- latest is < ${threshold_days}d old; no vetted version yet ($AURWEB/$p)")
        fi
    done

    (( ${#r_maint[@]} + ${#r_step[@]} + ${#r_orphan[@]} + ${#r_hold[@]} == 0 )) && return 0
    local x a b c d
    {
        echo
        echo "=============================================================="
        echo " AUR quarantine -- manual follow-ups"
        echo "=============================================================="
        if (( ${#r_maint[@]} )); then
            echo; echo " [!] MAINTAINER CHANGED -- verify on the AUR before trusting:"
            for x in "${r_maint[@]}"; do IFS='|' read -r a b c d <<<"$x"
                echo "     $a   ($b -> $c)"; echo "         check:  $d"; echo "         trust:  aur-quarantine accept $a"; done
        fi
        if (( ${#r_step[@]} )); then
            echo; echo " [^] Can step to an older, vetted version (latest still too new):"
            for x in "${r_step[@]}"; do IFS='|' read -r a b c <<<"$x"
                echo "     $a  ->  $b"; echo "         check:  $c"; echo "         update: aur-quarantine update $a"; done
        fi
        if (( ${#r_orphan[@]} )); then
            echo; echo " [x] ORPHANED (no maintainer) -- held:"
            for x in "${r_orphan[@]}"; do IFS='|' read -r a b <<<"$x"; echo "     $a   ($b)"; done
        fi
        if (( ${#r_hold[@]} )); then
            echo; echo " [-] Held (too new):"
            for x in "${r_hold[@]}"; do echo "     $x"; done
        fi
        echo
        echo " Tip: to always take a package's updates immediately (a maintainer you"
        echo "      fully trust):  aur-quarantine auto <pkg>   (changes are still flagged)"
        echo "=============================================================="
    } >&2
}

is_exempt_p() { load_exempt_once; [[ -n ${exempt[$1]+x} ]]; }
load_exempt_once() { [[ -n ${_exempt_loaded:-} ]] && return 0; load_exempt; _exempt_loaded=1; }

cmd_build() {                   # $1=pkgbase $2=sha  (installs)
    (( $# == 2 )) || { echo "usage: aur-quarantine build PKGBASE SHA" >&2; return 2; }
    local base=$1 sha=$2 dir
    dir=$(fetch_repo "$base") || { echo "aur-quarantine: build $base: fetch failed." >&2; return 1; }
    git -C "$dir" checkout --quiet "$sha" 2>/dev/null || { echo "aur-quarantine: build $base: checkout ${sha:0:8} failed." >&2; return 1; }
    if ( cd "$dir" && makepkg -si --noconfirm ); then
        git -C "$dir" checkout --quiet - 2>/dev/null || true; return 0
    fi
    echo "aur-quarantine: build $base @ ${sha:0:8} failed (deps/build/source) -- holding; upgrade manually if needed." >&2
    git -C "$dir" checkout --quiet - 2>/dev/null || true; return 1
}

cmd_update() {                  # manual: build the newest vetted (aged) version of PKG(s)
    (( $# )) || { echo "usage: aur-quarantine update PKG..." >&2; return 2; }
    local threshold_days="${AUR_QUARANTINE_DAYS:-14}"
    load_baseline; local now; now=$(date +%s)
    local p n base lm mt od inst cutoff repo res sha ver
    for p in "$@"; do
        IFS=$'\t' read -r n base lm mt od < <(rpc_info "$p")
        if [[ -z ${base:-} ]]; then echo "aur-quarantine: $p not found in AUR RPC." >&2; continue; fi
        if [[ -n ${trusted[$p]+x} && ${trusted[$p]} != "$mt" ]]; then
            echo "aur-quarantine: $p maintainer changed (${trusted[$p]:-ORPHANED} -> ${mt:-ORPHANED}). Verify $AURWEB/$p, then 'aur-quarantine accept $p' first." >&2; continue
        fi
        repo=$(fetch_repo "$base") || { echo "aur-quarantine: could not fetch AUR git ($base)." >&2; continue; }
        inst=$("$PACMAN" -Q "$p" 2>/dev/null | awk '{print $2}')
        cutoff=$(( now - threshold_days*86400 ))
        if res=$(target_at_or_before "$repo" "$cutoff" "$inst"); then
            sha=${res%%$'\t'*}; ver=${res#*$'\t'}
            echo "aur-quarantine: building $p $ver (pinned ${sha:0:8})..." >&2
            if cmd_build "$base" "$sha"; then trusted[$p]=$mt; save_baseline; echo "aur-quarantine: $p updated to $ver." >&2; fi
        else
            echo "aur-quarantine: $p has no version older than ${threshold_days}d to step to yet." >&2
        fi
    done
}

case "${1:-}" in
    seed)         shift; cmd_seed "$@" ;;
    accept)       shift; cmd_accept "$@" ;;
    auto)         shift; cmd_auto "$@" ;;
    auto-off)     shift; cmd_auto_off "$@" ;;
    update)       shift; cmd_update "$@" ;;
    build)        shift; cmd_build "$@" ;;
    ""|plan)      cmd_plan ;;
    -h|--help)    grep -E '^#( |$)' "$0" | sed 's/^# \{0,1\}//' ;;
    *)            echo "aur-quarantine: unknown subcommand '$1' (plan|update|accept|auto|auto-off|seed|build)" >&2; exit 2 ;;
esac
