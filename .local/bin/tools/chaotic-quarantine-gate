#!/usr/bin/env bash
# chaotic-quarantine-gate — pacman PreTransaction gate for chaotic-aur binaries
# (Story 2.28). Chaotic packages are ordinary repo packages, so yay's Lua hooks
# never see their installs; this alpm hook applies the same trust ladder
# (~/.config/yay/quarantine-policy.lua) to every chaotic-sourced target —
# metapac sync, ad-hoc `yay -S`, raw `pacman -S/-Syu` alike. A hold exits
# nonzero and AbortOnFail cancels the whole transaction before anything lands.
#
# Runs as root with alpm's sparse environment: user env vars never reach it,
# so the bypass is a consumable flag file (`aur-quarantine bypass-once`), not
# AUR_QUARANTINE_BYPASS. Paths are literal (alpm expands nothing) — same
# tradeoff as the 2.15 metapac-dedeclare hook.
#
# Holds land in held-install.tsv (pkg<TAB>code), the same file bootstrap's
# unattended sync loop remediates: "age" auto-steps via `aur-quarantine
# update` (an AUR source build at a pinned aged commit — same recipe chaotic
# builds from), identity holds die with the remedy.
# Docs: knowledge/reference/aur-malware-mitigation.md
set -uo pipefail

# Literal home on purpose (see header). The env override exists for the test
# harness only — alpm's sparse hook environment never sets it.
user_home="${CHAOTIC_GATE_HOME:-/home/aaron}"
state_dir="$user_home/.local/state/aur-quarantine"
policy="$user_home/.config/yay/quarantine-policy.lua"
days="${AUR_QUARANTINE_DAYS:-14}"
infra='^(chaotic-keyring|chaotic-mirrorlist)$' # the repo's own non-AUR packages

# --- collect chaotic-sourced targets (stdin: one pkgname per line) -----------
chaotic=()
while IFS= read -r pkg; do
    [[ -n "$pkg" ]] || continue
    [[ "$pkg" =~ $infra ]] && continue
    repo=$(pacman -Si "$pkg" 2>/dev/null | awk -F': *' '/^Repository/ { print $2; exit }')
    [[ "$repo" == "chaotic-aur" ]] && chaotic+=("$pkg")
done
((${#chaotic[@]} == 0)) && exit 0

# --- one-transaction bypass (consumed on sight) -------------------------------
if [[ -f "$state_dir/bypass-once" ]]; then
    rm -f "$state_dir/bypass-once"
    echo "aur-quarantine: chaotic gate BYPASSED once (${chaotic[*]}) — flag consumed"
    exit 0
fi

# --- stepping allowlist (consumed per package) ---------------------------------
# `aur-quarantine update` installs a vetted aged build via makepkg/pacman -U;
# without this the gate aborts that very install — it only sees the package
# NAME plus the too-new AUR latest (2026-07-10: aged ngrok 3.39.8 blocked
# while chaotic carried 3.39.9). Each entry approves exactly one transaction
# for exactly that package; everything else in the transaction stays gated.
if [[ -f "$state_dir/stepping.txt" ]]; then
    remaining=()
    for pkg in "${chaotic[@]}"; do
        if grep -qxF "$pkg" "$state_dir/stepping.txt" 2>/dev/null; then
            grep -vxF "$pkg" "$state_dir/stepping.txt" >"$state_dir/stepping.txt.new" 2>/dev/null || : >"$state_dir/stepping.txt.new"
            mv "$state_dir/stepping.txt.new" "$state_dir/stepping.txt"
            chown --reference="$user_home" "$state_dir/stepping.txt" 2>/dev/null || true
            echo "aur-quarantine: $pkg — vetted aged build being stepped in; allowing this transaction"
        else
            remaining+=("$pkg")
        fi
    done
    chaotic=("${remaining[@]}")
    ((${#chaotic[@]} == 0)) && exit 0
fi

hold() { # $1=pkg $2=code $3=why (remedies follow on stdin of caller-built msg)
    mkdir -p "$state_dir"
    printf '%s\t%s\n' "$1" "$2" >"$state_dir/held-install.tsv"
    chown --reference="$user_home" "$state_dir" "$state_dir/held-install.tsv" 2>/dev/null || true
    printf 'aur-quarantine: HOLD %s — %s\n     check:  https://aur.archlinux.org/packages/%s\n' "$1" "$3" "$1"
    shift 3
    printf '     %s\n' "$@"
    exit 1
}

# --- tooling must exist once a chaotic target is in play (fail closed) --------
for tool in curl jq lua5.1; do
    command -v "$tool" >/dev/null \
        || hold "${chaotic[0]}" rpc "cannot verify — '$tool' missing (failing closed)" \
            "install it:  pacman -S $tool   (bootstrap step 4b does this)"
done
[[ -f "$policy" ]] \
    || hold "${chaotic[0]}" rpc "policy module missing ($policy) — failing closed" \
        "restore it:  yadm checkout ~/.config/yay/quarantine-policy.lua"

# --- batched AUR RPC: name<TAB>lastmod<TAB>maintainer per package -------------
args=()
for pkg in "${chaotic[@]}"; do args+=(--data-urlencode "arg[]=$pkg"); done
rpc=$(curl -fsG --max-time 20 "${args[@]}" 'https://aur.archlinux.org/rpc/v5/info' 2>/dev/null \
    | jq -r '.results[] | [.Name, (.LastModified|tostring), (.Maintainer // "")] | @tsv') \
    || hold "${chaotic[0]}" rpc "AUR RPC unreachable — cannot verify (failing closed)" \
        "transient? retry — or:  aur-quarantine bypass-once   (next transaction only)"

now=$(date +%s)
for pkg in "${chaotic[@]}"; do
    line=$(grep -m1 -P "^\Q$pkg\E\t" <<<"$rpc" || true)
    [[ -n "$line" ]] || hold "$pkg" rpc "not found in AUR RPC — cannot verify (failing closed)" \
        "transient? retry — or:  aur-quarantine bypass-once   (next transaction only)"
    IFS=$'\t' read -r _ lm mt <<<"$line"
    # the policy's hold message names the version (2.32 — it printed "version ?"
    # while the gate withheld it); the sync DB has it, one cheap query per target
    ver=$(pacman -Si "$pkg" 2>/dev/null | awk -F': *' '/^Version/ { print $2; exit }')

    known="@never"
    if [[ -f "$state_dir/maintainers.tsv" ]]; then
        k=$(grep -m1 -P "^\Q$pkg\E\t" "$state_dir/maintainers.tsv" | cut -f2- || true)
        grep -q -P "^\Q$pkg\E\t" "$state_dir/maintainers.tsv" 2>/dev/null && known="${k:-@orphan}"
    fi
    exempt=0
    grep -qxF "$pkg" "$state_dir/exempt.txt" 2>/dev/null && exempt=1
    age="@nil"
    [[ "$lm" =~ ^[0-9]+$ && "$lm" -gt 0 ]] && age=$(((now - lm) / 86400))

    if ! out=$(lua5.1 "$policy" "$pkg" "${mt:-@orphan}" "$known" "$exempt" "$age" "$days" "${ver:-?}"); then
        code=${out%%$'\t'*}
        code=${code%%$'\n'*}
        why=$(head -1 <<<"$out" | cut -f2-)
        mapfile -t remedies < <(tail -n +2 <<<"$out")
        hold "$pkg" "$code" "$why (chaotic-aur binary)" "${remedies[@]}"
    fi
done
exit 0
