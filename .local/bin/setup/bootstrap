#!/usr/bin/env bash
# bootstrap — take a fresh Arch install to this repo's fully configured machine.
#
# yadm clone lays down the dotfiles; this script does everything else a new
# machine needs: decrypt secrets, render the machine's class profile, install
# yay, hand the declared package set to metapac (a fresh install is just the
# first reconcile), seed the AUR trust baseline, and set up zsh. Re-runnable:
# every step checks state before acting, so it doubles as repair.
#
# Thin by design (docs/decision-bootstrap-architecture.md): the hard parts are
# delegated — yadm owns files/secrets, metapac owns package idempotency, yay
# owns AUR builds + the quarantine (tools/aur-quarantine).
#
# Usage:
#   bootstrap               attended — each mutating tool shows its plan and prompts
#   bootstrap --check       dry-run: mutates nothing, prints what each step would do
#                           in this machine's state. Guards still fail for real, so it
#                           doubles as a cheap preflight for profile/config mistakes
#   bootstrap --unattended  no prompts — VM/harness runs; tools get their no-confirm
#                           flags, and secret decrypt is skipped (yadm decrypt later)
#   bootstrap -h            print this help
#
# Preconditions (docs/runbook-fresh-machine-bootstrap.md):
#   1. Arch installed (archinstall is fine): network up, user created, sudo works
#   2. sudo pacman -S --needed git base-devel yadm
#   3. yadm clone <repo-url>            # places dotfiles, incl. this script
#
# METAL GATE: until Story 2.10 lands (install-time AUR gating + portable trust
# baseline), run this only in disposable VMs (setup/vm-harness) — a fresh
# machine installs its AUR set ungated against freshly-weaponized packages.
set -euo pipefail

say() { printf '\n==> %s\n' "$*"; }
die() {
    printf '\nbootstrap: FATAL: %s\n' "$*" >&2
    exit 1
}
usage() { sed -n '2,/^set -euo/{/^set -euo/d; s/^# \{0,1\}//p;}' "$0"; } # the header is the help

CHECK=0
UNATTENDED=0
for arg in "$@"; do
    case "$arg" in
        --check) CHECK=1 ;;
        --unattended) UNATTENDED=1 ;; # harness/VM runs: pass tools their no-confirm flags
        -h | --help)
            usage
            exit 0
            ;;
        *) die "unknown argument: $arg   (try: bootstrap -h)" ;;
    esac
done
NC=()
[[ $UNATTENDED -eq 1 ]] && NC=(--noconfirm)

[[ $EUID -ne 0 ]] || die "run as your normal user, not root (sudo is invoked where needed)"
command -v pacman >/dev/null || die "pacman not found — this bootstrap is Arch-only"
yadm rev-parse --git-dir >/dev/null 2>&1 \
    || die "yadm repo not present — run the runbook preconditions first (yadm clone)"

# --- metal gate (Story 2.10 prerequisite) -----------------------------------
# systemd-detect-virt prints "none" AND exits nonzero on bare metal; empty output
# (binary missing) also gates conservatively.
virt=$(systemd-detect-virt 2>/dev/null || true)
if [[ -z "$virt" || "$virt" == "none" ]]; then
    say "WARNING: bare metal detected — Story 2.10 (install-time AUR gating) has not landed."
    if [[ $CHECK -eq 1 ]]; then
        echo "  (--check: would require typing 'metal' to continue)"
    elif [[ $UNATTENDED -eq 1 ]]; then
        die "unattended runs are VM-only until Story 2.10 lands (and there's no TTY to type 'metal')"
    else
        read -r -p "  Type 'metal' to continue anyway, anything else aborts: " ans
        [[ "$ans" == "metal" ]] || die "aborted at the metal gate"
    fi
fi

# --- 1. secrets (yadm decrypt; passphrase-interactive, contents never printed) ---
say "Secrets"
archive="$HOME/.local/share/yadm/archive"
if [[ ! -f "$archive" ]]; then
    echo "  no encrypted archive at $archive — nothing to decrypt"
elif [[ -f "$HOME/.zshenv" ]]; then
    echo "  secrets appear decrypted already (~/.zshenv exists) — skipping"
    echo "  (re-run manually anytime: yadm decrypt)"
elif [[ $UNATTENDED -eq 1 ]]; then
    echo "  unattended: skipping decrypt — a passphrase prompt can't run without a TTY"
    echo "  (if this machine needs secrets, run manually: yadm decrypt)"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: yadm decrypt   (interactive passphrase prompt)"
else
    yadm decrypt
fi

# --- 2. profile guard ----------------------------------------------------------
# A class is this machine's profile: one word (e.g. workstation) that decides
# which package groups — and someday maybe which dotfiles — this machine gets.
# It lives in yadm's local, untracked config: the repo carries every profile,
# and each machine just declares which one applies to it.
#
# Why yadm.class for a metapac concern? metapac wants a literal hostname->groups
# map, but hostnames shouldn't be committed to a public repo, and a fresh
# machine's hostname isn't knowable in advance anyway. yadm already owns the
# "render machine-specific files from tracked templates" problem
# (config.toml##template + yadm alt), so metapac just reads the rendered result
# — and any future per-class dotfile (work-vs-home shell config, say) reuses
# the same single knob instead of growing a second profile mechanism.
#
# The guard is strict because the failure mode is silent: with no class the
# template renders no [hostname_groups] entry, `metapac sync` does NOTHING, and
# a later `clean` would offer to remove every package on the machine. Picking
# the class IS the "desktop optional unless explicitly selected" decision.
say "Profile guard"
class=$(yadm config local.class 2>/dev/null || true)
[[ -n "$class" ]] || die "yadm.class is unset. Pick this machine's profile, then re-run:
    yadm config local.class <class>    # e.g. workstation (see runbook class table)
    yadm alt"
echo "  class: $class"
if [[ $CHECK -eq 0 ]]; then
    # (Re)render ##templates for this class+hostname. Usually redundant — yadm
    # auto-renders when local.class changes — but it also covers
    # yadm.auto-alt=false and hand-edited local configs.
    yadm alt >/dev/null || true
fi
cfg="$HOME/.config/metapac/config.toml"
[[ -f "$cfg" ]] || die "rendered metapac config missing ($cfg) — run 'yadm alt' and re-run"
grep -q "^\"$(uname -n)\" = \[" "$cfg" \
    || die "no [hostname_groups] entry for host '$(uname -n)' in $cfg.
    The template only renders known classes — check the class ('$class') against
    config.toml##template's branches, then: yadm alt   and re-run"
echo "  hostname entry: present"

# --- 3. machine-local group (untracked, never published) ----------------------
# The one group file living outside the repo; hostname_groups references it by
# absolute path and metapac hard-errors if it's missing, so a fresh machine
# needs it to exist (empty is fine). Must match config.toml##template's path —
# if they drift, metapac's own error names the missing path.
say "Machine-local group"
ml="$HOME/.local/share/metapac/machine-local.toml"
if [[ -f "$ml" ]]; then
    echo "  ok: $ml"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: create empty $ml"
else
    mkdir -p "$(dirname "$ml")"
    printf '# machine-local metapac group — untracked, never published\n[arch]\npackages = [\n]\n' >"$ml"
    echo "  created empty: $ml"
fi

# --- 3b. pacman mirrors (reflector) --------------------------------------------
# One slow mirror can stretch the first sync from minutes into hours. Fresh
# installs are usually fine — the archiso ranks mirrors at live-boot and
# pacstrap copies that list in — so re-rank only when the list has aged out.
# Steady-state re-ranking on live machines is Story 2.18 (reflector.timer).
say "Pacman mirrors"
mirrorlist=/etc/pacman.d/mirrorlist
if [[ -n "$(find "$mirrorlist" -mtime -7 2>/dev/null)" ]]; then
    echo "  mirrorlist is younger than 7 days — keeping it"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: pacman -S reflector, then rank the fastest US https mirrors"
else
    sudo pacman -S --needed "${NC[@]}" reflector
    sudo reflector --verbose --country 'United States' --fastest 10 --latest 10 \
        --sort rate --protocol https --age 6 --save "$mirrorlist"
fi

# --- 4. yay (AUR helper; one manual makepkg, everything else goes through it) ---
say "yay"
if command -v yay >/dev/null; then
    echo "  already installed"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: git clone aur.archlinux.org/yay-bin + makepkg -si"
else
    tmp=$(mktemp -d)
    git clone --depth 1 https://aur.archlinux.org/yay-bin.git "$tmp/yay-bin"
    (cd "$tmp/yay-bin" && makepkg -si "${NC[@]}")
    rm -rf "$tmp"
fi

# --- 5. metapac (itself an AUR package) --------------------------------------
say "metapac"
if command -v metapac >/dev/null; then
    echo "  already installed"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: yay -S --needed metapac"
else
    yay -S --needed "${NC[@]}" metapac
fi

# --- 5a. multilib (lib32-* packages in the desktop group need it) -------------
say "multilib repo"
if grep -q '^\[multilib\]' /etc/pacman.conf; then
    echo "  already enabled"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: enable [multilib] in /etc/pacman.conf + pacman -Sy"
else
    sudo sed -i '/^#\[multilib\]/,+1 s/^#//' /etc/pacman.conf
    grep -q '^\[multilib\]' /etc/pacman.conf || die "failed to enable [multilib] in /etc/pacman.conf"
    sudo pacman -Sy
fi

# --- 6. reconcile: the fresh install is just the first reconcile --------------
say "Package reconcile (metapac shows its plan and prompts)"
if [[ $CHECK -eq 1 ]]; then
    echo "  would: metapac sync   (installs this class's declared set, AUR via yay;"
    echo "         per-package service hooks fire as declared in the groups)"
elif [[ $UNATTENDED -eq 1 ]]; then
    # The AUR throttles clone bursts (connection resets when yay pre-fetches ~100
    # PKGBUILDs; seen in 2.7 VM validation). Retries are incremental: fetched
    # clones persist in yay's cache, so each attempt shrinks the remainder.
    # Resolver failures are different: they repeat identically on every attempt
    # (the 2026-07-08 dotnet provider conflict burned all 5 retries), so a
    # known-deterministic pacman error dies immediately instead (Story 2.26).
    sync_ok=0
    sync_log=$(mktemp)
    for attempt in 1 2 3 4 5; do
        metapac sync --no-confirm 2>&1 | tee "$sync_log" && {
            sync_ok=1
            break
        }
        fatal=$(grep -m1 -E 'unresolvable package conflicts detected|target not found:' "$sync_log" || true)
        [[ -z "$fatal" ]] || die "sync failed deterministically — fix the declarations. Decisive line: $fatal"
        echo "bootstrap: sync attempt $attempt failed — retrying in 90s"
        # Purge corrupt built archives (e.g. truncated by a disk-full episode):
        # yay reuses cached builds, so one bad .pkg.tar.zst poisons every retry.
        for f in "$HOME"/.cache/yay/*/*.pkg.tar.zst; do
            [[ -f "$f" ]] || continue
            pacman -Qp "$f" >/dev/null 2>&1 || {
                echo "  purging corrupt $(basename "$f")"
                rm -f "$f"
            }
        done
        sleep 90
    done
    [[ $sync_ok -eq 1 ]] || die "metapac sync failed after 5 attempts"
else
    metapac sync
fi

# --- 6b. normalize install reasons ---------------------------------------------
# pacman tags each package "explicit" (a human asked for it) or "dependency",
# and `metapac unmanaged` trusts that tag: explicit + undeclared = reported
# drift. The sync leaves wrong tags behind — yay installs built AUR files via
# `pacman -U --asexplicit`, and the flag paints every target in the transaction:
# split-package siblings and AUR-of-AUR deps too, not just declared packages
# (2.7 VM). Repair: an explicit-but-undeclared package that something requires
# is really a dependency — retag it (metadata-only; installs/removes nothing).
# Requirer-less explicits stay visible on purpose: that's real drift to triage.
say "Normalizing install reasons"
if [[ $CHECK -eq 1 ]]; then
    echo "  would: pacman -D --asdeps every explicit-but-undeclared package that has a requirer"
else
    # The sed is coupled to metapac's output shape (quoted package names): if a
    # metapac release reformats `unmanaged`, this loop silently becomes a no-op.
    # The harness's exactly-empty unmanaged assert is what would catch that.
    while IFS= read -r p; do
        [[ -n "$p" ]] || continue
        if [[ -n "$(pactree -r -d1 "$p" 2>/dev/null | sed -n 2p)" ]]; then
            sudo pacman -D -q --asdeps "$p" >/dev/null 2>&1 && echo "  dep-marked: $p"
        fi
    done < <(metapac unmanaged 2>/dev/null | sed -n 's/^\s*"\([^"]*\)".*/\1/p')
fi

# --- 6c. package-removal hook (Story 2.15) -------------------------------------
# Uninstalls de-declare themselves: an alpm hook (not yay — its Lua API has no
# removal event) runs tools/metapac-dedeclare on every removal, `yay -R` and raw
# `pacman -R` alike. Symlinked, not copied: content stays current with yadm pulls.
say "Package-removal hook"
hook_src="$HOME/.config/dotfiles/pacman-hooks/metapac-dedeclare.hook"
hook_dst="/etc/pacman.d/hooks/metapac-dedeclare.hook"
if [[ "$(readlink "$hook_dst" 2>/dev/null)" == "$hook_src" ]]; then
    echo "  already installed"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: symlink $hook_dst -> $hook_src"
else
    sudo mkdir -p /etc/pacman.d/hooks
    sudo ln -sfT "$hook_src" "$hook_dst"
fi

# --- 7. interim AUR trust baseline (Story 2.10 replaces with a portable one) ---
say "AUR quarantine baseline"
if [[ $CHECK -eq 1 ]]; then
    echo "  would: aur-quarantine seed   (trust-first-seen; interim until 2.10)"
else
    "$HOME/.local/bin/tools/aur-quarantine" seed || true
fi

# --- 8. oh-my-zsh (official installer; not a pacman package) ------------------
say "oh-my-zsh"
if [[ -d "$HOME/.oh-my-zsh" ]]; then
    echo "  already installed"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: run the official installer (RUNZSH=no CHSH=no KEEP_ZSHRC=yes)"
else
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

# --- 8b. oh-my-zsh custom theme (patched agnoster prompt; Story 2.20) ----------
# Tracked outside the omz checkout on purpose: a yadm-placed file inside
# ~/.oh-my-zsh would pre-create the dir and make step 8 skip the real install.
# custom/ shadows the bundled theme by name and is gitignored by omz, so
# updates never touch it.
say "oh-my-zsh custom theme"
theme_src="$HOME/.config/dotfiles/oh-my-zsh-custom/themes/agnoster.zsh-theme"
theme_dst="$HOME/.oh-my-zsh/custom/themes/agnoster.zsh-theme"
[[ -f "$theme_src" ]] || die "tracked theme missing ($theme_src) — yadm checkout incomplete?"
if [[ -L "$theme_dst" && "$(readlink "$theme_dst")" == "$theme_src" ]]; then
    echo "  already linked"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: ln -sf $theme_src \\"
    echo "                $theme_dst"
else
    mkdir -p "${theme_dst%/*}"
    ln -sf "$theme_src" "$theme_dst"
fi

# --- 9. login shell ------------------------------------------------------------
say "Login shell"
if [[ "${SHELL:-}" == */zsh ]]; then
    echo "  already zsh"
elif [[ $CHECK -eq 1 ]]; then
    echo "  would: chsh -s /usr/bin/zsh"
else
    chsh -s /usr/bin/zsh
fi

say "Bootstrap complete — reboot to land in the configured session."
echo "  steady state: setup/update (drift report at the end); yay -Syu is quarantine-gated."
