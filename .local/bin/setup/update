echo $'\n\nUpdating Azure CLI devops extension' #must be installed first
az extension update --name azure-devops

echo $'\n\nUpdating Azure SSH extension' #must be installed first
az extension update --name ssh

echo $'\n\nUpdating terraform tools...'
tenv tf install latest-allowed
tenv tf use latest-allowed
tenv atmos install latest-allowed
tenv atmos use latest-allowed

echo $'\n\nUpdating all Vundle packages for Vim...'
vim -i NONE -c VundleUpdate -c quitall

echo $'\n\n Updating aider...'
uv tool install --force --python python3.12 --with pip aider-ce@latest

echo $'\n\n Updating rust...'
rustup update stable
