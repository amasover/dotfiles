#!/usr/bin/env zsh
source ~/.zsh_plugins.sh

# --- options ---
# AUR upgrades are quarantined by default (see .local/bin/tools/aur-quarantine).
#   --aur-now   bypass the quarantine: upgrade ALL AUR packages now, incl. -git/--devel.
aur_now=false
for _arg in "$@"; do
  case "$_arg" in
    --aur-now) aur_now=true ;;
    -h|--help) print -- "usage: update [--aur-now]\n  --aur-now  bypass AUR quarantine; upgrade all AUR + devel packages now"; exit 0 ;;
  esac
done

# prevent sudo timeout
sudo -v
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

vared -p $'\nUpdate Spacemacs? (will kill any running emacs) (y/n): ' -c update_emacs

if [[ "${update_emacs}" == "y" ]]; then
    echo $'\nStarting Spacemacs upgrade. Be sure to update your dotfile (SPC f e D)'
    echo $'\nKilling emacs...'
    i3-msg '[class="Emacs"] kill' >> /dev/null
    echo $'\nUpdating Spacemacs from Github repo...'
    cd /home/$USER/.emacs.d
    git stash
    git pull
    git stash pop
    echo $'\nUpdating installed emacs packages (batch, synchronous)...\n'
    # Spacemacs' update-packages only backs up and DELETES old package dirs; the
    # new versions install on the next startup. Run both halves here in batch so
    # the script waits, sees failures, and no half-installed package survives a
    # closed window (see knowledge/errors/spacemacs-half-installed-package.md).
    if emacs --batch -l "$HOME/.emacs.d/init.el" \
             --eval '(configuration-layer/update-packages t)'; then
        echo $'\nInstalling updated packages (batch restart)...'
        emacs --batch -l "$HOME/.emacs.d/init.el" \
            || echo $'\nWARNING: emacs package reinstall reported errors above.'
    else
        echo $'\nWARNING: emacs package update failed; see output above.'
    fi

    # Guard: a package dir without its autoloads file is a half-finished install;
    # package.el thinks it is installed and every later startup fails with
    # "Cannot open load file". Catch it now instead of at next launch.
    # (elpa/develop is flat because dotspacemacs-elpa-subdirectory is nil.)
    elpa_dir="$HOME/.emacs.d/elpa/develop"
    broken_pkgs=()
    for d in "$elpa_dir"/*(N/); do
        [[ "${d:t}" == "archives" || "${d:t}" == "gnupg" ]] && continue
        base="${${d:t}%-[0-9]*}"
        [[ -f "$d/${base}-autoloads.el" ]] || broken_pkgs+=("${d:t}")
    done
    if (( ${#broken_pkgs} )); then
        echo $'\nWARNING: half-installed emacs packages (missing autoloads):'
        printf '  %s\n' "${broken_pkgs[@]}"
        echo 'Fix: rm -r the dir(s) above and start emacs to reinstall them.'
    fi

    echo $'\nRelaunching emacs...'
    i3-msg 'exec --no-startup-id emacs' >> /dev/null
else
    echo $'\nSkipping emacs update.'
fi

echo "Updating all system and AUR packages..."

# AUR upgrades are gated in-flow by the yay Lua quarantine hook (~/.config/yay/init.lua):
# it holds AUR packages that are too new (< ~14d), orphaned, or maintainer-changed, and
# writes a manual-follow-ups report. Repo packages are never held. Devel (-git) rebuilds
# only happen with --aur-now. See knowledge/reference/aur-malware-mitigation.md.
quarantine=$HOME/.local/bin/tools/aur-quarantine
"$quarantine" seed || true   # trust first-seen AUR packages' current maintainers (announced)
if [[ "$aur_now" == true ]]; then
    echo $'\nAUR quarantine bypassed (--aur-now): upgrading everything incl. devel...'
    AUR_QUARANTINE_BYPASS=1 yay -Syu --devel --sudoloop --noconfirm --timeupdate --answerupgrade none --answerdiff none --answeredit none --answerclean none --useask
else
    yay -Syu --sudoloop --noconfirm --answerupgrade none --answerdiff none --answeredit none --answerclean none --useask
    # Held packages + copy-paste follow-ups (accept / update / auto), written by the hook.
    aq_report="${XDG_STATE_HOME:-$HOME/.local/state}/aur-quarantine/last-report.txt"
    [[ -s "$aq_report" ]] && cat "$aq_report"
fi

echo $'\n\nUpdating oh-my-zsh...'
cd /home/$USER/.oh-my-zsh
git stash
git pull
git stash pop

echo $'\n\nUpdating all custom zsh packages...'
antibody update

echo $'\n\nUpdate nvm itself to the latest version...'
nvm upgrade

nvm_ver=$(<"${HOME}"/.nvmrc)
echo $'\n\nUpdating nodejs to latest version on branch' "${nvm_ver}"
nvm install "${nvm_ver}" --reinstall-packages-from=default

echo $'\n\nUpdating npm...'
npm install -g npm@latest

echo $'\n\nUpdating all global npm packages...'
npm update -g
npm -g --prefix /home/aaron/.emacs.d/.cache/copilot update

echo $'\n\nUpdating all global yarn packages'
yarn global upgrade --non-interactive

echo $'\n\nUpdating all pipx packages...'
pipx upgrade-all


